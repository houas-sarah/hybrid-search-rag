# Copy to .env and tweak. Every value has a default, so an empty .env works too
# (except you need a GROQ_API_KEY if LLM_PROVIDER=groq).

# paths
DOCS_DIR=./data/docs
CHROMA_PERSIST_DIR=./data/chroma
SPARSE_INDEX_PATH=./data/bm25/sparse_index.pkl
COLLECTION_NAME=internal_docs

# chunking (tokens)
CHUNK_SIZE=512
CHUNK_OVERLAP=51

# models (pulled from the HF hub on first run)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
DEVICE=cpu

# retrieval
TOP_K_DENSE=10
TOP_K_SPARSE=10
RRF_K=60
TOP_N_RERANK=3

# generation: ollama (local) or groq (free cloud tier)
LLM_PROVIDER=ollama
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

OLLAMA_MODEL=llama3
OLLAMA_HOST=http://localhost:11434

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# build the index at startup if empty (set true on ephemeral hosts like HF Spaces)
INGEST_ON_STARTUP=false
